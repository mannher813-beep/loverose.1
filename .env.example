# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Supabase Configuration
# You must set these in your environment / Secrets panel
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-secret"

# Money Fusion Payment Configuration
MONEY_FUSION_API_KEY="your-money-fusion-api-key"
MONEY_FUSION_MERCHANT_ID="your-merchant-id"
MONEY_FUSION_API_URL="https://pay.moneyfusion.net/LoveRose/5e63aa25ec22c9fa/pay/"
USE_LIVE_PAYMENT="false" # Set to "true" to enable the real Money Fusion gateway redirect
